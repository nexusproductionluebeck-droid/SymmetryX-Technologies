{
  "expo": {
    "name": "MagnaX",
    "slug": "magnax",
    "version": "0.1.0",
    "scheme": "magnax",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.symmetryx.magnax",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "MagnaX uses Bluetooth to discover and configure MagnaX ceiling devices during setup.",
        "NSBluetoothPeripheralUsageDescription": "MagnaX uses Bluetooth to pair with MagnaX ceiling devices.",
        "NSLocationWhenInUseUsageDescription": "Location is required on iOS to scan for nearby Bluetooth devices."
      }
    },
    "android": {
      "package": "com.symmetryx.magnax",
      "permissions": [
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B3A5C"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
