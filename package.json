{
  "name": "symmetryx-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MagnaX platform monorepo — mobile app, desktop app, shared packages.",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @magnax/mobile start",
    "mobile:ios": "pnpm --filter @magnax/mobile ios",
    "mobile:android": "pnpm --filter @magnax/mobile android",
    "desktop": "pnpm --filter @magnax/desktop dev",
    "desktop:build": "pnpm --filter @magnax/desktop build",
    "shared:build": "pnpm --filter @magnax/shared build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
